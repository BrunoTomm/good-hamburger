@page "/pedidos"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject PedidoService PedidoService
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Meus Pedidos</h3>
    <a href="/pedidos/novo" class="btn btn-warning">+ Novo Pedido</a>
</div>

@if (_resultado is null)
{
    <p>Carregando...</p>
}
else if (_resultado.Items.Count == 0)
{
    <div class="alert alert-secondary">Nenhum pedido encontrado.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Itens</th>
                <th>Subtotal</th>
                <th>Desconto</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in _resultado.Items)
            {
                <tr>
                    <td>@pedido.CriadoEm.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@string.Join(", ", pedido.Itens.Select(i => i.Nome))</td>
                    <td>@pedido.Subtotal.ToString("C")</td>
                    <td>
                        @if (pedido.PercentualDesconto > 0)
                        {
                            <span class="badge bg-success">-@((int)(pedido.PercentualDesconto * 100))%</span>
                        }
                    </td>
                    <td><strong>@pedido.Total.ToString("C")</strong></td>
                    <td>
                        <a href="/pedidos/@pedido.Id/editar" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => RemoverAsync(pedido.Id)">Remover</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= _resultado.TotalPaginas; i++)
            {
                var pagina = i;
                <li class="page-item @(pagina == _paginaAtual ? "active" : "")">
                    <button class="page-link" @onclick="() => CarregarAsync(pagina)">@pagina</button>
                </li>
            }
        </ul>
    </nav>
}

@code {
    private PagedResult<PedidoDto>? _resultado;
    private int _paginaAtual = 1;

    protected override async Task OnInitializedAsync() => await CarregarAsync(1);

    private async Task CarregarAsync(int pagina)
    {
        _paginaAtual = pagina;
        _resultado = await PedidoService.ListarAsync(pagina);
    }

    private async Task RemoverAsync(Guid id)
    {
        await PedidoService.RemoverAsync(id);
        await CarregarAsync(_paginaAtual);
    }
}
