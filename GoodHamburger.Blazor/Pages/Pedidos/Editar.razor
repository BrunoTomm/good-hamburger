@page "/pedidos/{Id:guid}/editar"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject PedidoService PedidoService
@inject CardapioService CardapioService
@inject NavigationManager Nav

<h3>Editar Pedido</h3>

@if (_cardapio is null || _pedido is null)
{
    <p>Carregando...</p>
}
else
{
    @if (_erro is not null)
    {
        <div class="alert alert-danger">@_erro</div>
    }

    <div class="row">
        @foreach (var item in _cardapio)
        {
            <div class="col-md-4 mb-3">
                <div class="card @(_selecionados.Contains(item.Nome) ? "border-warning" : "")">
                    <div class="card-body">
                        <h6>@item.Nome</h6>
                        <small class="text-muted">@item.Categoria</small>
                        <p class="mt-1 mb-2"><strong>@item.Preco.ToString("C")</strong></p>
                        <button class="btn btn-sm @(_selecionados.Contains(item.Nome) ? "btn-warning" : "btn-outline-warning")"
                                @onclick="() => ToggleItem(item.Nome)">
                            @(_selecionados.Contains(item.Nome) ? "✓ Selecionado" : "Selecionar")
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <button class="btn btn-warning" @onclick="SalvarAsync" disabled="@(_carregando || _selecionados.Count == 0)">
            @(_carregando ? "Salvando..." : "Salvar")
        </button>
        <a href="/pedidos" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private List<ItemCardapioDto>? _cardapio;
    private PedidoDto? _pedido;
    private HashSet<string> _selecionados = [];
    private string? _erro;
    private bool _carregando;

    protected override async Task OnInitializedAsync()
    {
        var tasks = await Task.WhenAll(
            CardapioService.ObterAsync().ContinueWith(t => { _cardapio = t.Result; return 0; }),
            PedidoService.ObterAsync(Id).ContinueWith(t =>
            {
                _pedido = t.Result;
                if (_pedido is not null)
                    _selecionados = [.. _pedido.Itens.Select(i => i.Nome)];
                return 0;
            }));
    }

    private void ToggleItem(string nome)
    {
        if (!_selecionados.Add(nome))
            _selecionados.Remove(nome);
    }

    private async Task SalvarAsync()
    {
        _erro = null;
        _carregando = true;
        var resultado = await PedidoService.AtualizarAsync(Id, [.. _selecionados]);
        _carregando = false;

        if (resultado is not null)
            Nav.NavigateTo("/pedidos");
        else
            _erro = "Não foi possível atualizar o pedido.";
    }
}
