@page "/pedidos/novo"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject PedidoService PedidoService
@inject CardapioService CardapioService
@inject NavigationManager Nav

<h3>Novo Pedido</h3>

@if (_cardapio is null)
{
    <p>Carregando cardápio...</p>
}
else
{
    @if (_erro is not null)
    {
        <div class="alert alert-danger">@_erro</div>
    }

    <div class="row">
        @foreach (var item in _cardapio)
        {
            <div class="col-md-4 mb-3">
                <div class="card @(_selecionados.Contains(item.Nome) ? "border-warning" : "")">
                    <div class="card-body">
                        <h6>@item.Nome</h6>
                        <small class="text-muted">@item.Categoria</small>
                        <p class="mt-1 mb-2"><strong>@item.Preco.ToString("C")</strong></p>
                        <button class="btn btn-sm @(_selecionados.Contains(item.Nome) ? "btn-warning" : "btn-outline-warning")"
                                @onclick="() => ToggleItem(item.Nome)">
                            @(_selecionados.Contains(item.Nome) ? "✓ Adicionado" : "Adicionar")
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <button class="btn btn-warning" @onclick="CriarAsync" disabled="@(_carregando || _selecionados.Count == 0)">
            @(_carregando ? "Criando..." : "Criar Pedido")
        </button>
        <a href="/pedidos" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </div>
}

@code {
    private List<ItemCardapioDto>? _cardapio;
    private readonly HashSet<string> _selecionados = [];
    private string? _erro;
    private bool _carregando;

    protected override async Task OnInitializedAsync() =>
        _cardapio = await CardapioService.ObterAsync();

    private void ToggleItem(string nome)
    {
        if (!_selecionados.Add(nome))
            _selecionados.Remove(nome);
    }

    private async Task CriarAsync()
    {
        _erro = null;
        _carregando = true;
        var pedido = await PedidoService.CriarAsync([.. _selecionados]);
        _carregando = false;

        if (pedido is not null)
            Nav.NavigateTo("/pedidos");
        else
            _erro = "Não foi possível criar o pedido. Verifique as regras do cardápio.";
    }
}
