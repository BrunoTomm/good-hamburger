@page "/cardapio"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject CardapioService CardapioService

<h3>Cardápio</h3>

@if (_itens is null)
{
    <p>Carregando...</p>
}
else
{
    @foreach (var grupo in _itens.GroupBy(i => i.Categoria))
    {
        <h5 class="mt-4">@grupo.Key</h5>
        <table class="table table-hover">
            <thead>
                <tr><th>Item</th><th>Tipo</th><th>Preço</th></tr>
            </thead>
            <tbody>
                @foreach (var item in grupo)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td><span class="badge bg-secondary">@item.Tipo</span></td>
                        <td>@item.Preco.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="alert alert-info mt-3">
        <strong>Combos com desconto:</strong><br/>
        Sanduíche + Batata + Refrigerante → 20% off<br/>
        Sanduíche + Refrigerante → 15% off<br/>
        Sanduíche + Batata → 10% off
    </div>
}

@code {
    private List<ItemCardapioDto>? _itens;

    protected override async Task OnInitializedAsync() =>
        _itens = await CardapioService.ObterAsync();
}
