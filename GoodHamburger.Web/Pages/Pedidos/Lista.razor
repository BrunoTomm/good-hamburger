@page "/pedidos"
@inject PedidoService PedidoService
@inject NavigationManager Nav

<PageTitle>Meus Pedidos -- Good Hamburger</PageTitle>

<div class="gh-container">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <h2 class="gh-section-title" style="margin:0;">Meus Pedidos</h2>
        <a href="/cardapio" class="btn-primary-gh">+ Novo Pedido</a>
    </div>

    @if (_pedidos is null)
    {
        <div class="gh-spinner"><div class="spinner"></div> Carregando...</div>
    }
    else if (!_pedidos.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">&#x1F4CB;</div>
            <p class="empty-state-title">Nenhum pedido ainda</p>
            <p class="empty-state-text">Faca seu primeiro pedido agora!</p>
            <a href="/cardapio" class="btn-primary-gh">Ver Cardapio</a>
        </div>
    }
    else
    {
        @foreach (var pedido in _pedidos.Items)
        {
            <div class="pedido-card">
                <div class="pedido-icon">&#x1F354;</div>
                <div class="pedido-info">
                    <p class="pedido-date">@pedido.CriadoEm.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="pedido-items">@string.Join(", ", pedido.Itens.Select(i => i.Nome))</p>
                    <p class="pedido-total">
                        @pedido.Total.ToString("C")
                        @if (pedido.PercentualDesconto > 0)
                        {
                            <span class="badge-discount">-@((int)(pedido.PercentualDesconto * 100))%</span>
                        }
                    </p>
                </div>
                <div class="pedido-actions">
                    <a href="/pedidos/@pedido.Id/editar" class="btn-outline-gh" style="padding:7px 12px; font-size:0.85rem;">Editar</a>
                    <button class="btn-outline-gh" style="padding:7px 12px; font-size:0.85rem; color:var(--primary); border-color:var(--primary);"
                            @onclick="() => ConfirmarRemocao(pedido.Id)">
                        Remover
                    </button>
                </div>
            </div>
        }

        @if (_pedidos.TotalPaginas > 1)
        {
            <div class="gh-pagination">
                @for (int i = 1; i <= _pedidos.TotalPaginas; i++)
                {
                    var pg = i;
                    <button class="@("gh-page-btn" + (pg == _pagina ? " active" : ""))" @onclick="() => MudarPagina(pg)">@pg</button>
                }
            </div>
        }
    }

    @if (_confirmarRemocaoId.HasValue)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:300;display:flex;align-items:center;justify-content:center;">
            <div style="background:white;border-radius:12px;padding:28px 32px;max-width:380px;width:90%;text-align:center;">
                <p style="font-size:1.05rem;font-weight:600;margin-bottom:8px;">Remover pedido?</p>
                <p style="color:#757575;font-size:0.9rem;margin-bottom:24px;">Esta acao nao pode ser desfeita.</p>
                <div style="display:flex;gap:12px;justify-content:center;">
                    <button class="btn-outline-gh" @onclick="() => _confirmarRemocaoId = null">Cancelar</button>
                    <button class="btn-primary-gh" @onclick="RemoverConfirmado">Sim, remover</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private PagedResult<PedidoDto>? _pedidos;
    private int _pagina = 1;
    private Guid? _confirmarRemocaoId;

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync() =>
        _pedidos = await PedidoService.ListarAsync(_pagina);

    private async Task MudarPagina(int pg) { _pagina = pg; await CarregarAsync(); }

    private void ConfirmarRemocao(Guid id) => _confirmarRemocaoId = id;

    private async Task RemoverConfirmado()
    {
        if (_confirmarRemocaoId is null) return;
        await PedidoService.RemoverAsync(_confirmarRemocaoId.Value);
        _confirmarRemocaoId = null;
        await CarregarAsync();
    }
}
